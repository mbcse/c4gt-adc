generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int                @id @default(autoincrement())
  name         String
  email        String             @unique
  password     String
  role         Role
  createdAt    DateTime           @default(now())
  assignments  CourseAssignment[]
  quizAttempts QuizAttempt[]
  watchLogs    WatchLog[]
}

enum Role {
  SUPERADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

model Course {
  id           Int                @id @default(autoincrement())
  title        String
  description  String?
  createdBy    String?
  createdAt    DateTime
  thumbnailUrl String?
  assignments  CourseAssignment[]
  courseVideos CourseVideo[]
}

model CourseAssignment {
  id         Int      @id @default(autoincrement())
  course     Course   @relation(fields: [courseId], references: [id])
  courseId   Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  assignedAt DateTime

  @@index([userId, courseId])
}

model CourseVideo {
  id       Int    @id @default(autoincrement())
  course   Course @relation(fields: [courseId], references: [id])
  courseId Int
  video    Video  @relation(fields: [videoId], references: [id])
  videoId  Int
  order    Int

  @@index([courseId, order])
}

model Video {
  id           Int           @id @default(autoincrement())
  title        String
  platform     String
  videoUrl     String
  videoId      String
  duration     Int
  createdAt    DateTime
  courseVideos CourseVideo[]
  watchLogs    WatchLog[]
  quiz         Quiz?
}

model WatchLog {
  id                Int      @id @default(autoincrement())
  user              User     @relation(fields: [userId], references: [id])
  userId            Int
  video             Video    @relation(fields: [videoId], references: [id])
  videoId           Int
  totalWatchTime    Int // in seconds
  isCompleted       Boolean  @default(false)
  watchedPercentage Float    @default(0.0)
  skipEvents        Json     @default("[]")
  pauseEvents       Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, videoId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([videoId, isCompleted])
}

model Quiz {
  id          Int           @id @default(autoincrement())
  video       Video         @relation(fields: [videoId], references: [id])
  videoId     Int           @unique
  generatedBy String?
  createdAt   DateTime
  questions   Json
  attempts    QuizAttempt[]
}

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  quizId      Int
  score       Float
  completedAt DateTime
}
